#!/usr/bin/env bash
# lathe — Autonomous code improvement loop.
# Point it at any repo and start turning.
#
# Usage:
#   lathe init [--type go|python|node|k8s|generic] [--tool claude|amp]
#   lathe start [--cycles N] [--tool claude|amp]
#   lathe stop
#   lathe status [--follow]
#   lathe logs [--follow]

set -euo pipefail

# Resolve symlinks to find the real install directory
_self="${BASH_SOURCE[0]}"
while [[ -L "$_self" ]]; do
    _dir="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
LATHE_HOME="$(cd "$(dirname "$_self")/.." && pwd)"
unset _self _dir
LATHE_DIR=".lathe"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

die() { echo "error: $*" >&2; exit 1; }

ensure_initialized() {
    [[ -d "$LATHE_DIR" ]] || die "Not a lathe project. Run 'lathe init' first."
    [[ -f "$LATHE_DIR/agent.md" ]] || die "Missing $LATHE_DIR/agent.md. Run 'lathe init' first."
    [[ -f "$LATHE_DIR/snapshot.sh" ]] || die "Missing $LATHE_DIR/snapshot.sh. Run 'lathe init' first."
}

# ---------------------------------------------------------------------------
# init — introspect project and generate .lathe/
# ---------------------------------------------------------------------------

detect_type() {
    if [[ -f "go.mod" ]] || ls *.go &>/dev/null; then
        echo "go"
    elif [[ -f "Cargo.toml" ]]; then
        echo "rust"
    elif [[ -f "package.json" ]]; then
        echo "node"
    elif [[ -f "pyproject.toml" ]] || [[ -f "setup.py" ]] || [[ -f "requirements.txt" ]]; then
        echo "python"
    elif [[ -d "platform/charts" ]]; then
        echo "k8s"
    else
        echo "generic"
    fi
}

collect_project_context() {
    local project_type="$1"
    local repo_name
    repo_name=$(basename "$(pwd)")

    echo "Project: $repo_name"
    echo "Type: $project_type"
    echo ""

    # README
    if [[ -f "README.md" ]]; then
        echo "=== README.md ==="
        head -100 README.md
        echo ""
    fi

    # Top-level files and directories
    echo "=== Top-level files ==="
    ls -1
    echo ""

    # Dependency / config files
    for f in go.mod go.sum package.json Cargo.toml pyproject.toml setup.py requirements.txt Makefile Dockerfile docker-compose.yml; do
        if [[ -f "$f" ]]; then
            echo "=== $f ==="
            head -30 "$f"
            echo ""
        fi
    done

    # cmd/ directory (indicates CLI)
    if [[ -d "cmd" ]]; then
        echo "=== cmd/ ==="
        ls -1 cmd/
        echo ""
    fi

    # deploy/charts directory (indicates K8s)
    for d in deploy charts platform/charts; do
        if [[ -d "$d" ]]; then
            echo "=== $d/ ==="
            ls -1 "$d/"
            echo ""
        fi
    done
}

generate_agent() {
    local tool="$1"
    local project_type="$2"
    local context="$3"

    local priority_stack=""
    if [[ -f "$LATHE_HOME/templates/$project_type/priority-stack.md" ]]; then
        priority_stack=$(cat "$LATHE_HOME/templates/$project_type/priority-stack.md")
    elif [[ -f "$LATHE_HOME/templates/generic/priority-stack.md" ]]; then
        priority_stack=$(cat "$LATHE_HOME/templates/generic/priority-stack.md")
    fi

    # Build prompt via temp file to avoid bash substitution issues
    local tmp_prompt
    tmp_prompt=$(mktemp)

    python3 -c "
import sys
tpl = open('$LATHE_HOME/templates/meta-prompt.md').read()
ctx = sys.stdin.read()
stack = open('/dev/fd/3').read()
tpl = tpl.replace('{{PROJECT_CONTEXT}}', ctx)
tpl = tpl.replace('{{PRIORITY_STACK}}', stack)
print(tpl)
" 3<<< "$priority_stack" <<< "$context" > "$tmp_prompt"

    # Call AI (|| true to prevent set -e from aborting)
    local rc=0
    if [[ "$tool" == "claude" ]]; then
        claude --dangerously-skip-permissions --print < "$tmp_prompt" || rc=$?
    elif [[ "$tool" == "amp" ]]; then
        amp --dangerously-allow-all < "$tmp_prompt" || rc=$?
    else
        rm -f "$tmp_prompt"
        return 1
    fi
    rm -f "$tmp_prompt"
    return "$rc"
}

cmd_init() {
    local project_type=""
    local tool="claude"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type) project_type="$2"; shift 2 ;;
            --tool) tool="$2"; shift 2 ;;
            *)      die "Unknown option: $1" ;;
        esac
    done

    if [[ -z "$project_type" ]]; then
        project_type=$(detect_type)
        echo "  Detected project type: $project_type"
    fi

    local template_dir="$LATHE_HOME/templates/$project_type"
    if [[ ! -d "$template_dir" ]]; then
        echo "  No template for '$project_type', falling back to generic"
        template_dir="$LATHE_HOME/templates/generic"
        project_type="generic"
    fi

    [[ -d "$template_dir" ]] || die "Template directory not found: $template_dir"

    local reinit=false
    if [[ -d "$LATHE_DIR" ]]; then
        reinit=true
        echo "  Re-initializing (state preserved)."
    else
        echo ""
        echo "  ╔═══════════════════════════════════════════╗"
        echo "  ║  LATHE — initializing project              ║"
        echo "  ╚═══════════════════════════════════════════╝"
    fi
    echo ""

    mkdir -p "$LATHE_DIR/skills" "$LATHE_DIR/state/logs" "$LATHE_DIR/state/history"

    # Copy snapshot and skills from template
    cp "$template_dir/snapshot.sh" "$LATHE_DIR/snapshot.sh"
    chmod +x "$LATHE_DIR/snapshot.sh"

    if [[ -d "$template_dir/skills" ]]; then
        cp "$template_dir/skills/"*.md "$LATHE_DIR/skills/" 2>/dev/null || true
    fi

    # Generate agent.md via AI
    echo "  Analyzing project and generating agent ..."
    local context
    context=$(collect_project_context "$project_type")

    local agent_file="$LATHE_DIR/agent.md"
    local gen_exit=0
    generate_agent "$tool" "$project_type" "$context" > "$agent_file.tmp" || gen_exit=$?

    local tmp_size=0
    [[ -f "$agent_file.tmp" ]] && tmp_size=$(wc -c < "$agent_file.tmp" | tr -d ' ')
    echo "  (debug: exit=$gen_exit size=${tmp_size}b)"
    [[ -f "$agent_file.tmp" ]] && [[ "$tmp_size" -gt 0 ]] && echo "  (debug: first line: $(head -1 "$agent_file.tmp"))"

    if [[ "$gen_exit" -eq 0 ]] && [[ -s "$agent_file.tmp" ]] && grep -q "Lathe" "$agent_file.tmp"; then
        mv "$agent_file.tmp" "$agent_file"
        echo "  Agent generated via $tool."
    else
        rm -f "$agent_file.tmp"
        if [[ "$gen_exit" -ne 0 ]]; then
            echo "  WARN: AI generation failed (exit $gen_exit). Falling back to static template."
        else
            echo "  WARN: AI output didn't look right. Falling back to static template."
        fi
        _fallback_agent "$template_dir" "$project_type"
    fi

    # Add state/ to .gitignore if not already there
    if [[ -f .gitignore ]]; then
        if ! grep -q '\.lathe/state/' .gitignore 2>/dev/null; then
            echo "" >> .gitignore
            echo "# Lathe runtime state" >> .gitignore
            echo ".lathe/state/" >> .gitignore
        fi
    else
        echo "# Lathe runtime state" > .gitignore
        echo ".lathe/state/" >> .gitignore
    fi

    if $reinit; then
        echo "  Updated: agent.md, snapshot.sh, skills"
    else
        echo "  Created: $LATHE_DIR/"
    fi
    echo "  Agent:   $LATHE_DIR/agent.md"
    echo "  Skills:  $LATHE_DIR/skills/"
    echo "  Snap:    $LATHE_DIR/snapshot.sh"
    echo ""
    echo "  Run 'lathe start' to begin."
}

_fallback_agent() {
    local template_dir="$1"
    local project_type="$2"
    local repo_name
    repo_name=$(basename "$(pwd)")
    local repo_desc=""
    if [[ -f "README.md" ]]; then
        repo_desc=$(head -5 README.md | grep -v '^#' | head -1 | tr -d '\n' || true)
    fi
    cp "$template_dir/agent.md" "$LATHE_DIR/agent.md"
    sed -i '' "s|{{PROJECT_NAME}}|$repo_name|g" "$LATHE_DIR/agent.md" 2>/dev/null || true
    sed -i '' "s|{{PROJECT_TYPE}}|$project_type|g" "$LATHE_DIR/agent.md" 2>/dev/null || true
    sed -i '' "s|{{PROJECT_DESC}}|$repo_desc|g" "$LATHE_DIR/agent.md" 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# start/stop/status/logs — delegate to engine
# ---------------------------------------------------------------------------

cmd_start() {
    ensure_initialized
    source "$LATHE_HOME/engine/loop.sh"
    engine_start "$@"
}

cmd_stop() {
    ensure_initialized
    source "$LATHE_HOME/engine/loop.sh"
    engine_stop
}

cmd_status() {
    ensure_initialized
    source "$LATHE_HOME/engine/loop.sh"
    engine_status "$@"
}

cmd_logs() {
    ensure_initialized
    source "$LATHE_HOME/engine/loop.sh"
    engine_logs "$@"
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

case "${1:-help}" in
    init)    shift; cmd_init "$@" ;;
    start)   shift; cmd_start "$@" ;;
    stop)    cmd_stop ;;
    status)  shift; cmd_status "$@" ;;
    logs)    shift 2>/dev/null || true; cmd_logs "$@" ;;
    help|--help|-h)
        echo "Usage: lathe <command> [options]"
        echo ""
        echo "Commands:"
        echo "  init   [--type TYPE] [--tool NAME] Initialize project for lathe"
        echo "  start  [--cycles N] [--tool NAME] Start improvement loop"
        echo "  stop                              Stop running loop"
        echo "  status [--follow]                 Show current state"
        echo "  logs   [--follow]                 View cycle logs"
        echo ""
        echo "Project types: go, python, node, rust, k8s, generic"
        ;;
    *)
        die "Unknown command: $1. Run 'lathe help' for usage."
        ;;
esac
