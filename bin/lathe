#!/usr/bin/env bash
# lathe — Autonomous code improvement loop.
# Point it at any repo and start turning.
#
# Usage:
#   lathe init [--type go|python|node|k8s|generic] [--tool claude|amp]
#   lathe start [--cycles N] [--tool claude|amp]
#   lathe stop
#   lathe status [--follow]
#   lathe logs [--follow]

set -euo pipefail

# Resolve symlinks to find the real install directory
_self="${BASH_SOURCE[0]}"
while [[ -L "$_self" ]]; do
    _dir="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
LATHE_HOME="$(cd "$(dirname "$_self")/.." && pwd)"
unset _self _dir
LATHE_DIR=".lathe"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

die() { echo "error: $*" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Spinner — for long-running operations like `init` (5-10 min agent runs)
# ---------------------------------------------------------------------------
# Usage:
#   spinner_start "Analyzing project and generating agent"
#   ...long thing...
#   spinner_stop
#
# Suppressed when stdout is not a TTY (e.g. piped, CI). Always safe to call.

LATHE_SPINNER_PID=""

spinner_start() {
    local label="$1"
    [[ -t 1 ]] || { echo "  $label ..."; return; }

    local start
    start=$(date +%s)
    # Subshell: rotate frames + show elapsed time. Parent kills it via PID.
    (
        local frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
        local i=0
        while :; do
            local now elapsed mins secs frame
            now=$(date +%s)
            elapsed=$(( now - start ))
            mins=$(( elapsed / 60 ))
            secs=$(( elapsed % 60 ))
            frame=${frames:i:1}
            printf '\r  %s %s  %dm%02ds\033[K' "$frame" "$label" "$mins" "$secs"
            i=$(( (i + 1) % ${#frames} ))
            sleep 0.1
        done
    ) &
    LATHE_SPINNER_PID=$!
    # Make sure the spinner dies if the script is interrupted.
    trap 'spinner_stop' EXIT INT TERM
}

spinner_stop() {
    [[ -n "$LATHE_SPINNER_PID" ]] || return 0
    kill "$LATHE_SPINNER_PID" 2>/dev/null || true
    wait "$LATHE_SPINNER_PID" 2>/dev/null || true
    LATHE_SPINNER_PID=""
    # Clear the spinner line.
    [[ -t 1 ]] && printf '\r\033[K'
    trap - EXIT INT TERM
}

ensure_initialized() {
    [[ -d "$LATHE_DIR" ]] || die "Not a lathe project. Run 'lathe init' first."
    [[ -f "$LATHE_DIR/agent.md" ]] || die "Missing $LATHE_DIR/agent.md. Run 'lathe init' first."
    [[ -f "$LATHE_DIR/snapshot.sh" ]] || die "Missing $LATHE_DIR/snapshot.sh. Run 'lathe init' first."
}

# ---------------------------------------------------------------------------
# init — introspect project and generate .lathe/
# ---------------------------------------------------------------------------

detect_type() {
    if [[ -f "go.mod" ]] || ls *.go &>/dev/null; then
        echo "go"
    elif [[ -f "Cargo.toml" ]]; then
        echo "rust"
    elif [[ -f "package.json" ]]; then
        echo "node"
    elif [[ -f "pyproject.toml" ]] || [[ -f "setup.py" ]] || [[ -f "requirements.txt" ]]; then
        echo "python"
    elif [[ -d "platform/charts" ]]; then
        echo "k8s"
    else
        echo "generic"
    fi
}

generate_agent() {
    local tool="$1"
    local interactive="${2:-false}"

    local interactive_block=""
    if [[ "$interactive" == "true" ]]; then
        interactive_block=$(cat "$LATHE_HOME/templates/interactive-preamble.md")
    fi

    # Build prompt via temp file to avoid bash substitution issues
    local tmp_prompt
    tmp_prompt=$(mktemp)

    python3 -c "
tpl = open('$LATHE_HOME/templates/meta-prompt.md').read()
manifesto = open('$LATHE_HOME/templates/values-manifesto.md').read()
tpl = tpl.replace('{{VALUES_MANIFESTO}}', manifesto)
tpl = tpl.replace('{{INTERACTIVE}}', '''$interactive_block''')
print(tpl)
" > "$tmp_prompt"

    # Call AI — let it read the project and write .lathe/agent.md directly.
    # Interactive mode shows the agent live; autonomous mode is silent for
    # 5–10 minutes, so capture output to a log and show a spinner instead.
    local rc=0
    local log="$LATHE_DIR/init.log"
    if [[ "$tool" == "claude" ]]; then
        if [[ "$interactive" == "true" ]]; then
            claude "$(cat "$tmp_prompt")" --allowedTools "Read,Write,Edit,Glob,Grep" || rc=$?
        else
            spinner_start "Analyzing project and generating agent"
            claude -p "$(cat "$tmp_prompt")" --allowedTools "Read,Write,Edit,Glob,Grep" \
                > "$log" 2>&1 || rc=$?
            spinner_stop
        fi
    elif [[ "$tool" == "amp" ]]; then
        if [[ "$interactive" == "true" ]]; then
            amp --dangerously-allow-all < "$tmp_prompt" || rc=$?
        else
            spinner_start "Analyzing project and generating agent"
            amp --dangerously-allow-all < "$tmp_prompt" > "$log" 2>&1 || rc=$?
            spinner_stop
        fi
    else
        rm -f "$tmp_prompt"
        return 1
    fi
    rm -f "$tmp_prompt"
    return "$rc"
}

cmd_init() {
    local project_type=""
    local tool="claude"
    local interactive=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type)        project_type="$2"; shift 2 ;;
            --tool)        tool="$2"; shift 2 ;;
            --interactive) interactive=true; shift ;;
            *)             die "Unknown option: $1" ;;
        esac
    done

    if [[ -z "$project_type" ]]; then
        project_type=$(detect_type)
        echo "  Detected project type: $project_type"
    fi

    local template_dir="$LATHE_HOME/templates/$project_type"
    if [[ ! -d "$template_dir" ]]; then
        echo "  No template for '$project_type', falling back to generic"
        template_dir="$LATHE_HOME/templates/generic"
        project_type="generic"
    fi

    [[ -d "$template_dir" ]] || die "Template directory not found: $template_dir"

    local reinit=false
    if [[ -d "$LATHE_DIR" ]]; then
        reinit=true
        echo "  Re-initializing (preserving refs/)."

        # Wipe everything except refs/ — config gets regenerated,
        # session/history/decisions are session-scoped and stale.
        for item in "$LATHE_DIR"/* "$LATHE_DIR"/.*; do
            local base
            base=$(basename "$item")
            [[ "$base" == "." || "$base" == ".." ]] && continue
            [[ "$base" == "refs" ]] && continue
            rm -rf "$item"
        done
    else
        echo ""
        echo "  ╔═══════════════════════════════════════════╗"
        echo "  ║  LATHE — initializing project              ║"
        echo "  ╚═══════════════════════════════════════════╝"
    fi
    echo ""

    mkdir -p "$LATHE_DIR/skills" "$LATHE_DIR/refs"

    # Copy snapshot from template
    cp "$template_dir/snapshot.sh" "$LATHE_DIR/snapshot.sh"
    chmod +x "$LATHE_DIR/snapshot.sh"

    # Generate agent.md and skills via AI. generate_agent shows a spinner
    # in autonomous mode; interactive mode prints its own preamble.
    local gen_exit=0
    generate_agent "$tool" "$interactive" || gen_exit=$?

    if [[ "$gen_exit" -ne 0 ]]; then
        echo ""
        echo "  ERROR: Agent generation failed (exit $gen_exit)."
        echo "  The AI could not analyze this project. Check that '$tool' is installed and working."
        if [[ -s "$LATHE_DIR/init.log" ]]; then
            echo ""
            echo "  --- last 20 lines of $LATHE_DIR/init.log ---"
            tail -n 20 "$LATHE_DIR/init.log" | sed 's/^/  /'
            echo "  --- end ---"
        fi
        echo ""
        echo "  You can retry with: lathe init --tool $tool"
        echo "  If this persists, please report it: https://github.com/libliflin/lathe/issues"
        $reinit || rm -rf "$LATHE_DIR"
        exit 1
    fi

    if [[ ! -s "$LATHE_DIR/agent.md" ]] || ! grep -q "Lathe" "$LATHE_DIR/agent.md"; then
        echo ""
        echo "  ERROR: Agent generation produced unusable output."
        echo "  The AI ran but didn't produce a valid agent.md."
        echo "  You can retry with: lathe init --tool $tool"
        echo ""
        echo "  If this persists, please report it: https://github.com/libliflin/lathe/issues"
        $reinit || rm -rf "$LATHE_DIR"
        exit 1
    fi

    echo "  Agent generated via $tool."

    # Safety net: the meta-prompt instructs the init agent to chmod +x falsify.sh,
    # but agents sometimes forget. Without the executable bit, the engine silently
    # skips the falsification suite (engine/loop.sh checks `[[ -x ... ]]`).
    if [[ -f "$LATHE_DIR/falsify.sh" && ! -x "$LATHE_DIR/falsify.sh" ]]; then
        chmod +x "$LATHE_DIR/falsify.sh"
    fi

    # Ensure .lathe/session/ is gitignored (all ephemeral engine state)
    # Clean up old-style granular entries from previous versions.
    # Portable in-place edit (BSD sed needs `-i ''`, GNU sed on Linux/Git Bash
    # treats `''` as a filename) — use a temp file and move it back.
    if [[ -f .gitignore ]]; then
        local tmp_gitignore
        tmp_gitignore=$(mktemp) || tmp_gitignore=".gitignore.lathe.tmp.$$"
        # Strip old-style entries first, then collapse runs of blank lines.
        # Done as two passes because the blank-line collapse uses `N`, which
        # would otherwise pull the next line into the pattern space and hide
        # it from the deletion patterns.
        sed -e '/^\.lathe\/state/d' -e '/^# Lathe logs/d' .gitignore \
            | sed -e '/^$/N;/^\n$/d' > "$tmp_gitignore" \
            && mv "$tmp_gitignore" .gitignore
    fi
    if ! grep -qF ".lathe/session/" .gitignore 2>/dev/null; then
        [[ -f .gitignore ]] || touch .gitignore
        echo "" >> .gitignore
        echo "# Lathe session state (ephemeral, engine-managed)" >> .gitignore
        echo ".lathe/session/" >> .gitignore
    fi

    # Install global Claude Code skill (helps any Claude session understand lathe)
    local skill_dir="$HOME/.claude/skills/lathe"
    if [[ ! -f "$skill_dir/SKILL.md" ]] || ! diff -q "$LATHE_HOME/templates/skill/SKILL.md" "$skill_dir/SKILL.md" &>/dev/null; then
        mkdir -p "$skill_dir"
        cp "$LATHE_HOME/templates/skill/SKILL.md" "$skill_dir/SKILL.md"
        echo "  Skill:   ~/.claude/skills/lathe/ (updated)"
    fi

    if $reinit; then
        echo "  Updated: agent.md, snapshot.sh, skills"
    else
        echo "  Created: $LATHE_DIR/"
    fi
    echo "  Agent:   $LATHE_DIR/agent.md"
    echo "  Skills:  $LATHE_DIR/skills/"
    echo "  Snap:    $LATHE_DIR/snapshot.sh"
    if [[ -f "$LATHE_DIR/alignment-summary.md" ]]; then
        echo ""
        echo "  Review the alignment summary before starting:"
        echo "  cat $LATHE_DIR/alignment-summary.md"
        echo ""
        echo "  If something looks off, re-run with: lathe init --interactive"
    fi
    echo ""
    echo "  Run 'lathe start' to begin."
}

# ---------------------------------------------------------------------------
# start/stop/status/logs — delegate to engine
# ---------------------------------------------------------------------------

cmd_start() {
    ensure_initialized
    source "$LATHE_HOME/engine/loop.sh"
    engine_start "$@"
}

cmd_stop() {
    ensure_initialized
    source "$LATHE_HOME/engine/loop.sh"
    engine_stop
}

cmd_status() {
    ensure_initialized
    source "$LATHE_HOME/engine/loop.sh"
    engine_status "$@"
}

cmd_logs() {
    ensure_initialized
    source "$LATHE_HOME/engine/loop.sh"
    engine_logs "$@"
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

case "${1:-help}" in
    init)    shift; cmd_init "$@" ;;
    start)   shift; cmd_start "$@" ;;
    stop)    cmd_stop ;;
    status)  shift; cmd_status "$@" ;;
    logs)    shift 2>/dev/null || true; cmd_logs "$@" ;;
    help|--help|-h)
        echo "Usage: lathe <command> [options]"
        echo ""
        echo "Commands:"
        echo "  init   [--type TYPE] [--tool NAME]        Initialize project for lathe"
        echo "         [--interactive]                    Participate in stakeholder discovery"
        echo "  start  [--cycles N] [--tool NAME]         Start improvement loop"
        echo "         [--theme \"...\"]                    Purpose for this session"
        echo "         [--direct]                         Skip branch/PR, commit to current branch"
        echo "  stop                              Stop running loop"
        echo "  status [--follow]                 Show current state"
        echo "  logs   [--follow]                 View cycle logs"
        echo ""
        echo "Project types: go, python, node, rust, k8s, generic"
        ;;
    *)
        die "Unknown command: $1. Run 'lathe help' for usage."
        ;;
esac
